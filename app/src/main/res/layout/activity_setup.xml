<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="48dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/setup_title"
        android:textColor="@color/text_primary"
        android:textSize="32sp" />

    <TextView
        android:layout_width="640dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:text="@string/setup_body"
        android:textColor="@color/text_secondary"
        android:textSize="18sp" />

    <Button android:id="@+id/enableKeyboardButton" android:layout_width="360dp" android:layout_height="wrap_content" android:layout_marginTop="32dp" android:text="@string/enable_keyboard" />
    <Button android:id="@+id/chooseKeyboardButton" android:layout_width="360dp" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="@string/choose_keyboard" />
    <Button android:id="@+id/voicePermissionButton" android:layout_width="360dp" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="@string/voice_permission" />
</LinearLayout>
